{
  "__inputs": [],
  "__requires": [
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Attendix application log streams: errors, warnings, attendance events, and security alerts.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Number of log lines per level over time. Spikes in error/warn indicate issues.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warn" },  "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "info" },  "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "fillOpacity": 20,
        "gradientMode": "none",
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (count_over_time({job=\"docker\", container=~\".*(attendance|backend).*\"} [1m]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "title": "Log Volume by Level (backend)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Live stream of ERROR and WARN level log lines across all Attendix containers.",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 8 },
      "id": 2,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"docker\", container=~\".*(attendance|backend).*\", level=~\"error|warn|40|50\"} | json",
          "refId": "A"
        }
      ],
      "title": "Errors & Warnings — Live Stream",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Attendance submission events from the backend (module=attendance).",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 20 },
      "id": 3,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"docker\", container=~\".*backend.*\"} | json | module=\"attendance\"",
          "refId": "A"
        }
      ],
      "title": "Attendance Events",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Security-relevant events: auth failures, device flags, mobile spoofing, rate-limit hits.",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 20 },
      "id": 4,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"docker\", container=~\".*(attendance|backend).*\", level=~\"warn|40\"} | json | module=~\"auth|deviceCheck|webauthn|shortLinks\"",
          "refId": "A"
        }
      ],
      "title": "Security Events (warn level)",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "All Caddy access logs — HTTP requests passing through the reverse proxy.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 30 },
      "id": 5,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"docker\", container=\"attendance-caddy\"}",
          "refId": "A"
        }
      ],
      "title": "Caddy Access Logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "MongoDB and Redis container logs — connection events, auth failures, replication info.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 40 },
      "id": 6,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"docker\", container=~\".*(mongo|redis).*\"}",
          "refId": "A"
        }
      ],
      "title": "MongoDB / Redis Logs",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["attendix", "logs"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Attendix — Logs",
  "uid": "attendix-logs",
  "version": 1
}
