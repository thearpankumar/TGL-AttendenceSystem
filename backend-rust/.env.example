# ============================================
# CORE CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=CHANGE-THIS-TO-A-SECURE-RANDOM-STRING
JWT_EXPIRE=7d
ADMIN_SECRET=CHANGE-THIS-TO-SECURE-ADMIN-CREATION-SECRET

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGIN=*

# ============================================
# WEBAUTHN CONFIGURATION
# ============================================
WEBAUTHN_RP_NAME=Attendix Attendance System
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# ============================================
# STORAGE CONFIGURATION (S3)
# ============================================
STORAGE_PROVIDER=s3
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ============================================
# REDIS CACHE (optional)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# MONGODB CONNECTION
# ============================================
MONGODB_URI=mongodb://localhost:27017/attendance-geotag
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=5

# ============================================
# DEVELOPMENT BYPASS
# ============================================
DEV_BYPASS_ALL=false
DEV_BYPASS_MOBILE_CHECK=false

# ============================================
# LOGGING
# ============================================
RUST_LOG=info

# ============================================
# IP LOOKUP (optional)
# ============================================
IP_API_URL=http://ip-api.com/json/
