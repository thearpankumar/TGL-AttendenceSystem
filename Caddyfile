# Caddy Configuration for Attendance System
# Development Mode - localhost
{
	email admin@example.com

	local_certs

	# Admin API bound to all interfaces (not published to the host — only
	# reachable by other containers on web-net, e.g. Prometheus) so
	# /metrics can be scraped as caddy:2019/metrics.
	admin 0.0.0.0:2019
	metrics

	log {
		output stdout
		format json
	}
}

# ============================================
# DEVELOPMENT MODE (localhost)
# ============================================
:80 {
	encode gzip

	log {
		output file /var/log/caddy/access.log {
			roll_size 50MiB
			roll_keep 10
			roll_keep_for 720h
		}
		format json
	}

	# API routes
	handle /api/* {
		reverse_proxy backend:3000 {
			lb_policy round_robin
			lb_try_duration 5s
			health_uri /health
			health_interval 10s
			health_timeout 5s
		}
	}

	# Health check endpoints
	handle /health {
		reverse_proxy backend:3000
	}

	handle /health/ready {
		reverse_proxy backend:3000
	}

	handle /health/live {
		reverse_proxy backend:3000
	}

	# Admin panel (React app with client-side routing)
	handle_path /owner-of-attendix-xyz* {
		reverse_proxy admin-frontend:80
	}

	# Grafana (logs + metrics dashboards). NOT handle_path: with
	# GF_SERVER_SERVE_FROM_SUB_PATH=true, Grafana's own router expects the
	# full prefixed path — it does its own internal stripping.
	# Prometheus is intentionally NOT routed here — it has no login of its
	# own, so it stays internal-only (reachable only as prometheus:9090 by
	# Grafana, over monitoring-net).
	handle /logging-grafana-main* {
		reverse_proxy grafana:3000
	}

	# Student attendance page
	handle /attend/* {
		reverse_proxy student-frontend:80
	}

	# Student assets
	handle /attend-assets/* {
		reverse_proxy student-frontend:80
	}

	# Student app.js and face detection models
	handle /app.js {
		reverse_proxy student-frontend:80
	}

	handle /models/* {
		reverse_proxy student-frontend:80
	}

	# Short links (and WebAuthn routes which are mounted under /s)
	handle /s/* {
		rewrite * /api{path}
		reverse_proxy backend:3000
	}

	# 32-char hex token redirect to /attend/:token
	@tokenRegex path_regexp ^/([a-f0-9]{32})$
	handle @tokenRegex {
		redir /attend{http.matchers.path_regexp.1} permanent
	}

	# Home page (catch-all: matches / plus whatever asset paths the landing
	# page's build emits — every other route above is more specific and wins).
	handle {
		reverse_proxy home-frontend:3000
	}
}
