# Docker Compose Environment Variables
# Copy to .env and configure before running docker-compose up

# ============================================
# CORE CONFIGURATION
# ============================================
NODE_ENV=production
DOMAIN=your-domain.com

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=CHANGE-THIS-TO-A-SECURE-RANDOM-STRING
ADMIN_SECRET=CHANGE-THIS-TO-SECURE-ADMIN-CREATION-SECRET

# ============================================
# WEBAUTHN CONFIGURATION
# ============================================
WEBAUTHN_RP_NAME=Attendix Attendance System
WEBAUTHN_RP_ID=your-domain.com
WEBAUTHN_ORIGIN=https://your-domain.com

# ============================================
# STORAGE CONFIGURATION
# ============================================
# Choose: 'cloudinary' or 's3'
STORAGE_PROVIDER=s3

# Cloudinary (required when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# AWS S3 (required when STORAGE_PROVIDER=s3)
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ============================================
# REDIS CACHE
# ============================================
REDIS_PASSWORD=change_this_to_a_secure_redis_password
REDIS_URL=redis://:change_this_to_a_secure_redis_password@redis:6379

# ============================================
# MONGODB CONNECTION POOL
# ============================================
MONGODB_POOL_MAX=300
MONGODB_POOL_MIN=20

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# DEV_BYPASS_ALL: Controls the Developer Bypass Mode at the environment level.
# If true: 
#   - Injects mock buttons in the student frontend for testing (Bypass Camera/Location/WebAuthn).
#   - Relaxes backend constraints so mock submissions are accepted and recorded with a "flagged" audit trail.
# If false: 
#   - The system runs in strict production mode. Mock buttons are hidden.
#   - All hardware and location checks are strictly enforced and cannot be bypassed.
# Note: You can now also toggle this dynamically via the Admin Dashboard > Settings.
DEV_BYPASS_ALL=false
