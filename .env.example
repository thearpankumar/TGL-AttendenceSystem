# Docker Compose Environment Variables
# Copy to .env and configure before running docker-compose up

# ============================================
# CORE CONFIGURATION
# ============================================
NODE_ENV=production
JWT_SECRET=CHANGE-THIS-TO-A-SECURE-RANDOM-STRING
ADMIN_SECRET=CHANGE-THIS-TO-SECURE-ADMIN-CREATION-SECRET

# ============================================
# STORAGE CONFIGURATION
# ============================================
# Choose: 'cloudinary' or 's3'
# - cloudinary: Easier setup, automatic image optimization
# - s3: AWS native, direct browser upload via presigned URLs
STORAGE_PROVIDER=cloudinary

# Cloudinary (required when STORAGE_PROVIDER=cloudinary)
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# AWS S3 (required when STORAGE_PROVIDER=s3)
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ============================================
# NGROK CONFIGURATION (Optional)
# ============================================
# For public URL access during development/demo
# Sign up at: https://ngrok.com
# Get your auth token from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your-ngrok-auth-token

# Your custom ngrok domain (if you have one)
# Example: myapp.ngrok-free.app
NGROK_DOMAIN=your-ngrok-domain.ngrok-free.app

# ============================================
# S3 CORS CONFIGURATION (S3 only)
# ============================================
# Apply via AWS Console or CLI:
# aws s3api put-bucket-cors --bucket your-bucket --cors-configuration '{
#   "CORSRules": [{
#     "AllowedOrigins": ["*"],
#     "AllowedMethods": ["GET", "PUT", "POST", "HEAD"],
#     "AllowedHeaders": ["*"],
#     "ExposeHeaders": ["ETag"],
#     "MaxAgeSeconds": 3000
#   }]
# }'
